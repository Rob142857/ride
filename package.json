{
  "name": "ride",
  "version": "1.0.3",
  "private": true,
  "description": "Open-source trip planning PWA with waypoints, routes, journals, and sharing",
  "main": "index.html",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rob142857/ride.git"
  },
  "scripts": {
    "dev": "npx serve -p 3000",
    "start": "npx serve -p 3000",
    "deploy": "node scripts/deploy.js",
    "deploy:svelte-test": "node scripts/deploy-svelte-test.js",
    "db:create": "wrangler d1 create ride-db",
    "db:migrate": "wrangler d1 execute ride-db --file=./api/schema.sql",
    "db:migrate:local": "wrangler d1 execute ride-db --file=./api/schema.sql --local",
    "kv:create": "wrangler kv:namespace create RIDE_TRIP_PLANNER_SESSIONS",
    "dev:remote": "wrangler dev --remote --d1=RIDE_TRIP_PLANNER_DB --kv=RIDE_TRIP_PLANNER_SESSIONS --r2=RIDE_TRIP_PLANNER_ATTACHMENTS",
    "setup": "echo 'Run: npm run db:create && npm run kv:create && update wrangler.toml with IDs && npm run db:migrate'"
  },
  "keywords": [
    "pwa",
    "trip",
    "navigation",
    "waypoints",
    "journal",
    "cloudflare"
  ],
  "author": "Robert Evans - Objective Artefacts Australia",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "sharp": "^0.34.5",
    "wrangler": "^4.81.1"
  }
}
